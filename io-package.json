      },
      "0.1.3": {
        "en": "State name translations use standard ioBroker i18n framework",
        "de": "Datenpunktnamen-Übersetzungen nutzen das Standard-ioBroker-i18n-Framework",
        "ru": "Переводы имён состояний используют стандартный фреймворк i18n ioBroker",
        "pt": "Traduções dos nomes de estados utilizam o framework i18n padrão do ioBroker",
        "nl": "Vertalingen van statusnamen gebruiken het standaard ioBroker i18n-framework",
        "fr": "Les traductions des noms d'états utilisent le framework i18n standard d'ioBroker",
        "it": "Le traduzioni dei nomi degli stati utilizzano il framework i18n standard di ioBroker",
        "es": "Las traducciones de nombres de estados utilizan el framework i18n estándar de ioBroker",
        "pl": "Tłumaczenia nazw stanów wykorzystują standardowy framework i18n ioBroker",
        "uk": "Переклади назв станів використовують стандартний фреймворк i18n ioBroker",
        "zh-cn": "状态名称翻译使用标准ioBroker i18n框架"
      },
      "0.1.2": {
        "en": "User-modified state names are no longer overwritten on adapter restart",
        "de": "Vom Benutzer geänderte Datenpunktnamen werden beim Adapter-Neustart nicht mehr überschrieben",
        "ru": "Пользовательские имена состояний больше не перезаписываются при перезапуске адаптера",
        "pt": "Nomes de estados modificados pelo utilizador já não são substituídos ao reiniciar o adaptador",
        "nl": "Door de gebruiker gewijzigde statusnamen worden niet meer overschreven bij het herstarten van de adapter",
        "fr": "Les noms d'états modifiés par l'utilisateur ne sont plus écrasés lors du redémarrage de l'adaptateur",
        "it": "I nomi degli stati modificati dall'utente non vengono più sovrascritti al riavvio dell'adattatore",
        "es": "Los nombres de estados modificados por el usuario ya no se sobrescriben al reiniciar el adaptador",
        "pl": "Nazwy stanów zmienione przez użytkownika nie są już nadpisywane przy ponownym uruchomieniu adaptera",
        "uk": "Змінені користувачем назви станів більше не перезаписуються при перезапуску адаптера",
        "zh-cn": "用户修改的状态名称在适配器重启时不再被覆盖"
      },
      "0.1.1": {
        "en": "Use community-standard event handler pattern",
        "de": "Community-Standard Event-Handler-Pattern verwendet",
        "ru": "Использован стандартный шаблон обработчика событий сообщества",
        "pt": "Utilizado padrão de manipulador de eventos da comunidade",
        "nl": "Community-standaard event handler patroon gebruikt",
        "fr": "Utilisation du modèle de gestionnaire d'événements standard de la communauté",
        "it": "Utilizzato il pattern standard della comunità per i gestori di eventi",
        "es": "Utilizado el patrón estándar de la comunidad para manejadores de eventos",
        "pl": "Zastosowano standardowy wzorzec obsługi zdarzeń społeczności",
        "uk": "Використано стандартний шаблон обробника подій спільноти",
        "zh-cn": "使用社区标准事件处理程序模式"
      },
      "0.1.0": {
        "en": "Initial release — offline holiday detection for 206 countries with bridge day support",
        "de": "Erstveröffentlichung — Offline-Feiertagserkennung für 206 Länder mit Brückentag-Unterstützung",
        "ru": "Первый релиз — офлайн-определение праздников для 206 стран с поддержкой промежуточных дней",
        "pt": "Lançamento inicial — detecção offline de feriados para 206 países com suporte a dias ponte",
        "nl": "Eerste release — offline feestdagdetectie voor 206 landen met brugdagondersteuning",
        "fr": "Version initiale — détection hors ligne des jours fériés pour 206 pays avec support des jours de pont",
        "it": "Rilascio iniziale — rilevamento offline dei giorni festivi per 206 paesi con supporto giorni ponte",
        "es": "Lanzamiento inicial — detección offline de festivos para 206 países con soporte de días puente",
        "pl": "Pierwsze wydanie — wykrywanie świąt offline dla 206 krajów z obsługą dni pomostowych",
        "uk": "Перший реліз — офлайн-визначення свят для 206 країн із підтримкою перехідних днів",
        "zh-cn": "首次发布——支持206个国家的离线节假日检测及桥接日功能"
      }
    },
    "titleLang": {
      "en": "Public Holidays",
      "de": "Feiertage",
      "ru": "Государственные праздники",
      "pt": "Feriados",
      "nl": "Feestdagen",
      "fr": "Jours fériés",
      "it": "Giorni festivi",
      "es": "Días festivos",
      "pl": "Święta",
      "uk": "Святкові дні",
      "zh-cn": "公共假日"
    },
    "desc": {
      "en": "Detects public holidays for 206 countries — runs offline, updates daily at midnight",
      "de": "Erkennt Feiertage für 206 Länder — läuft offline, aktualisiert täglich um Mitternacht",
      "ru": "Определяет государственные праздники для 206 стран — работает офлайн, обновляется ежедневно в полночь",
      "pt": "Detecta feriados para 206 países — funciona offline, atualiza diariamente à meia-noite",
      "nl": "Detecteert feestdagen voor 206 landen — werkt offline, vernieuwt dagelijks om middernacht",
      "fr": "Détecte les jours fériés pour 206 pays — fonctionne hors ligne, mise à jour quotidienne à minuit",
      "it": "Rileva i giorni festivi per 206 paesi — funziona offline, aggiornamento giornaliero a mezzanotte",
      "es": "Detecta festivos para 206 países — funciona offline, se actualiza diariamente a medianoche",
      "pl": "Wykrywa święta dla 206 krajów — działa offline, aktualizacja codziennie o północy",
      "uk": "Визначає святкові дні для 206 країн — працює офлайн, оновлення щодня опівночі",
      "zh-cn": "检测206个国家的公共假日——离线运行，每日午夜自动更新"
    },
    "authors": [
      "krobi <krobi@power-dreams.com>"
    ],
    "licenseInformation": {
      "license": "MIT",
      "type": "free"
    },
    "platform": "Javascript/Node.js",
    "icon": "feiertage.svg",
    "extIcon": "https://cdn.jsdelivr.net/gh/krobipd/ioBroker.feiertage@main/admin/feiertage.svg",
    "readme": "https://github.com/krobipd/ioBroker.feiertage/blob/main/README.md",
    "enabled": true,
    "tier": 2,
    "loglevel": "info",
    "mode": "schedule",
    "schedule": "0 0 * * *",
    "type": "date-and-time",
    "compact": true,
    "connectionType": "local",
    "dataSource": "push",
    "adminUI": {
      "config": "json"
    },
    "supportedMessages": {
      "stopInstance": true
    },
    "dependencies": [
      {
        "js-controller": ">=7.0.7"
      }
    ],
    "globalDependencies": [
      {
        "admin": ">=7.8.23"
      }
    ],
    "keywords": [
      "holidays",
      "feiertage",
      "public holidays",
      "bank holidays",
      "bridge days",
      "calendar",
      "date-holidays"
    ]
  },
