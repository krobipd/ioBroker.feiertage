{
  "name": "iobroker.feiertage",
  "version": "0.1.4",
  "description": "ioBroker adapter for public holiday detection using date-holidays",
  "author": {
    "name": "krobi",
    "email": "krobi@power-dreams.com"
  },
  "contributors": [
    {
      "name": "Claude (Anthropic)",
      "role": "Coding assistance"
    }
  ],
  "homepage": "https://github.com/krobipd/ioBroker.feiertage",
  "license": "MIT",
  "keywords": [
    "ioBroker",
    "feiertage",
    "holidays",
    "public holidays",
    "bank holidays",
    "date-holidays",
    "calendar"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/krobipd/ioBroker.feiertage"
  },
  "engines": {
    "node": ">=22",
    "npm": ">=10"
  },
  "files": [
    "admin",
    "build",
    "io-package.json",
    "LICENSE",
    "README.md"
  ],
  "dependencies": {
    "@iobroker/adapter-core": "^3.3.2",
    "date-holidays": "^3.30.1"
  },
  "devDependencies": {
    "@alcalzone/release-script": "^5.2.0",
    "@alcalzone/release-script-plugin-iobroker": "^5.2.0",
    "@alcalzone/release-script-plugin-license": "^5.2.0",
    "@iobroker/adapter-dev": "^1.5.0",
    "@iobroker/eslint-config": "^2.3.4",
    "@iobroker/testing": "^5.2.2",
    "@tsconfig/node22": "^22.0.2",
    "@types/iobroker": "npm:@iobroker/types@^7.1.2",
    "@types/node": "^22",
    "@vitest/coverage-v8": "^4.1.6",
    "rimraf": "^6.1.3",
    "typescript": "~6.0.3",
    "vitest": "^4.1.6"
  },
  "main": "build/main.js",
  "scripts": {
    "prebuild": "rimraf build",
    "build": "build-adapter ts",
    "watch": "build-adapter ts --watch",
    "check": "tsc --noEmit",
    "test:ts": "vitest run",
    "test:package": "mocha test/package --exit",
    "test:integration": "mocha test/integration --exit",
    "test": "npm run test:ts && npm run test:package",
    "coverage": "vitest run --coverage",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "release": "release-script",
    "translate": "translate-adapter"
  },
  "bugs": {
    "url": "https://github.com/krobipd/ioBroker.feiertage/issues"
  }
}
